# Production Domain Reverse Proxy configuration for OdysseyAI
{$DEPLOY_DOMAIN:localhost} {
    # Route API and health endpoints to the FastAPI backend
    reverse_proxy /api/* 127.0.0.1:8000
    reverse_proxy /health 127.0.0.1:8000

    # Route all other traffic to the Next.js frontend
    reverse_proxy /* 127.0.0.1:3000
}
