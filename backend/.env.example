# =====================================================================
# OdysseyAI Backend - Environment Variables Example
# Copy this file to '.env' and fill in your actual API keys.
# =====================================================================

# 1. Gemini LLM brain Key (Required for Agent models)
GOOGLE_API_KEY="your_gemini_api_key_here"

# Optional: Set to True if using Google GenAI Enterprise endpoints
GOOGLE_GENAI_USE_ENTERPRISE=True

# 2. Google Maps API Key (Required for Stays, Food, Attractions, Geocoding, and Driving Directions)
GOOGLE_MAPS="your_google_maps_key_here"

# 3. Google Flights & Search Engine Key (Required for SerpAPI Searches and Google Flights)
SERP_API_KEY="your_serp_api_key_here"

# 4. Flight Search Configuration (Select 'serpapi' or 'skyscanner')
FLIGHT_PROVIDER="serpapi"

# Optional: Apify API Token (Only required if FLIGHT_PROVIDER is set to 'skyscanner')
APIFY_API_TOKEN="your_apify_api_token_here"
